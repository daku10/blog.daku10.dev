---
import { Icon } from "@/components/Icon";
import { Link } from "@/components/Link";

import Navigation from "./Navigation.astro";
import { SideMenu } from "./islands/SideMenu";
import { ThemeToggleButton } from "./islands/ThemeToggleButton";

type Props = {
  pathname: string;
};

const { pathname } = Astro.props;
---

<header class="py-6 md:py-12">
  <div class="flex items-center justify-between">
    <Link
      href="/"
      className="font-brand text-xl font-semibold text-primary antialiased md:text-3xl"
    >
      blog.daku10.dev
    </Link>
    <div class="-mr-2 flex items-center">
      <div class="hidden md:block">
        <Navigation pathname={pathname} />
      </div>
      <div class="ml-8 flex items-center">
        <div class="md:hidden">
          <SideMenu client:only="preact" pathname={pathname} />
        </div>
        <ThemeToggleButton client:only="preact" />
        <Link
          className="hidden md:block"
          href="/feed.xml"
          target="_blank"
          rel="noopener"
        >
          <Icon
            type="rss"
            className="h-10 w-10 p-2 text-secondary hover:text-primary"
          />
          <span class="sr-only">RSS</span>
        </Link>
        <Link
          className="hidden md:block"
          href="https://github.com/daku10/blog.daku10.dev"
          target="_blank"
          rel="noopener noreferrer"
        >
          <Icon
            type="github"
            className="h-10 w-10 p-2 text-secondary hover:text-primary"
          />
          <span class="sr-only">GitHub</span>
        </Link>
      </div>
    </div>
  </div>
</header>
