{
  "name": "blog.daku10.dev",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:preview": "astro build && printf '/*\\n  X-Robots-Tag: noindex, nofollow\\n' > out/_headers",
    "build:production": "astro build",
    "start": "serve out",
    "deploy": "pnpm wrangler deploy",
    "deploy:preview": "pnpm wrangler deploy --env=preview",
    "preview:workers": "wrangler dev",
    "lint": "concurrently 'pnpm:lint:*'",
    "lint:ts": "astro check",
    "lint:es": "oxlint --type-aware src astro.config.mjs tailwind.config.ts",
    "lint:markup": "markuplint './src/**/*.{j,t}sx'",
    "lint:text": "textlint src/content/posts/**/index.md",
    "lint:format": "oxfmt --check .",
    "analyze": "astro build",
    "format": "oxfmt --write ."
  },
  "dependencies": {
    "@astrojs/preact": "5.1.1",
    "@preact/signals": "2.9.0",
    "@tabler/icons-preact": "3.41.1",
    "astro": "6.1.10",
    "clsx": "2.1.1",
    "preact": "10.29.1",
    "rehype-autolink-headings": "7.1.0",
    "rehype-external-links": "3.0.0",
    "rehype-pretty-code": "0.14.3",
    "rehype-slug": "6.0.0",
    "remark-gfm": "4.0.1",
    "rss": "1.2.2",
    "satori": "0.26.0",
    "sharp": "0.34.5",
    "shiki": "4.0.2",
    "simple-icons": "16.17.0",
    "tailwind-merge": "3.5.0",
    "valibot": "1.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@markuplint/jsx-parser": "4.18.3",
    "@markuplint/ml-core": "4.18.3",
    "@markuplint/react-spec": "4.18.0",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.4",
    "@types/hast": "3.0.4",
    "@types/node": "24.12.2",
    "@types/rss": "0.0.32",
    "budoux": "0.8.1",
    "concurrently": "9.2.1",
    "markuplint": "4.18.3",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "0.21.1",
    "serve": "14.2.6",
    "tailwindcss": "4.2.4",
    "textlint": "15.5.4",
    "textlint-rule-preset-ja-spacing": "2.4.3",
    "textlint-rule-preset-ja-technical-writing": "12.0.2",
    "textlint-rule-spellcheck-tech-word": "5.0.0",
    "typescript": "6.0.3",
    "wrangler": "4.84.1"
  },
  "packageManager": "pnpm@10.33.1+sha512.05ba3c1d5d1c18f68df06470d74055e62d41fc110a0c660db1b2dfb2785327f04cf0f68345d4609bc52089e7fa0343c31593b2f9594e2c5d5da426230acc9820",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "es5-ext",
      "sharp"
    ],
    "patchedDependencies": {}
  }
}
