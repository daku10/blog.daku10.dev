{
  "name": "blog.daku10.dev",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:preview": "astro build && printf '/*\\n  X-Robots-Tag: noindex, nofollow\\n' > out/_headers",
    "build:production": "astro build",
    "start": "serve out",
    "deploy": "pnpm wrangler deploy",
    "deploy:preview": "pnpm wrangler deploy --env=preview",
    "preview:workers": "wrangler dev",
    "lint": "concurrently 'pnpm:lint:*'",
    "lint:ts": "astro check",
    "lint:es": "oxlint --type-aware src astro.config.mjs tailwind.config.ts",
    "lint:markup": "markuplint './src/**/*.{j,t}sx'",
    "lint:text": "textlint src/content/posts/**/index.md",
    "lint:format": "oxfmt --check .",
    "analyze": "astro build",
    "format": "oxfmt --write ."
  },
  "dependencies": {
    "@astrojs/preact": "5.1.2",
    "@preact/signals": "2.9.0",
    "@tabler/icons-preact": "3.44.0",
    "astro": "6.3.1",
    "clsx": "2.1.1",
    "preact": "10.29.1",
    "rehype-autolink-headings": "7.1.0",
    "rehype-external-links": "3.0.0",
    "rehype-pretty-code": "0.14.3",
    "rehype-slug": "6.0.0",
    "remark-gfm": "4.0.1",
    "rss": "1.2.2",
    "satori": "0.26.0",
    "sharp": "0.34.5",
    "shiki": "4.0.2",
    "simple-icons": "16.19.0",
    "tailwind-merge": "3.6.0",
    "valibot": "1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@markuplint/jsx-parser": "4.7.23",
    "@markuplint/ml-core": "4.13.3",
    "@markuplint/react-spec": "4.5.23",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.3.0",
    "@types/hast": "3.0.4",
    "@types/node": "24.12.3",
    "@types/rss": "0.0.32",
    "budoux": "0.8.3",
    "concurrently": "9.2.1",
    "markuplint": "4.14.1",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "0.22.1",
    "serve": "14.2.6",
    "tailwindcss": "4.3.0",
    "textlint": "15.6.1",
    "textlint-rule-preset-ja-spacing": "2.4.3",
    "textlint-rule-preset-ja-technical-writing": "12.0.2",
    "textlint-rule-spellcheck-tech-word": "5.0.0",
    "typescript": "6.0.3",
    "wrangler": "4.90.0"
  },
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "es5-ext",
      "sharp"
    ],
    "patchedDependencies": {}
  }
}
