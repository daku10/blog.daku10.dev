{
  "name": "blog.daku10.dev",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:preview": "astro build && printf '/*\\n  X-Robots-Tag: noindex, nofollow\\n' > out/_headers",
    "build:production": "astro build",
    "start": "serve out",
    "deploy": "pnpm wrangler deploy",
    "deploy:preview": "pnpm wrangler deploy --env=preview",
    "preview:workers": "wrangler dev",
    "lint": "concurrently 'pnpm:lint:*'",
    "lint:ts": "astro check",
    "lint:es": "oxlint --type-aware src astro.config.mjs tailwind.config.ts",
    "lint:markup": "markuplint './src/**/*.{j,t}sx'",
    "lint:text": "textlint public/posts/**/*.md",
    "lint:format": "oxfmt --check .",
    "analyze": "astro build",
    "format": "oxfmt --write ."
  },
  "dependencies": {
    "@astrojs/react": "5.0.2",
    "@headlessui/react": "2.2.9",
    "@tabler/icons-react": "3.41.1",
    "astro": "6.1.3",
    "clsx": "2.1.1",
    "gray-matter": "4.0.3",
    "image-size": "2.0.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-autolink-headings": "7.1.0",
    "rehype-external-links": "3.0.0",
    "rehype-pretty-code": "0.14.3",
    "rehype-slug": "6.0.0",
    "rehype-stringify": "10.0.1",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "rss": "1.2.2",
    "shiki": "4.0.2",
    "simple-icons": "16.14.0",
    "tailwind-merge": "3.5.0",
    "unified": "11.0.5",
    "unist-util-visit": "5.1.0",
    "valibot": "1.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@markuplint/jsx-parser": "4.7.23",
    "@markuplint/ml-core": "4.13.3",
    "@markuplint/react-spec": "4.5.23",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.2",
    "@types/hast": "3.0.4",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/rss": "0.0.32",
    "concurrently": "9.2.1",
    "markuplint": "4.14.1",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "oxlint-tsgolint": "0.19.0",
    "serve": "14.2.6",
    "tailwindcss": "4.2.2",
    "textlint": "15.5.2",
    "textlint-rule-preset-ja-spacing": "2.4.3",
    "textlint-rule-preset-ja-technical-writing": "12.0.2",
    "textlint-rule-spellcheck-tech-word": "5.0.0",
    "typescript": "5.9.3",
    "wrangler": "4.20.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "es5-ext",
      "sharp"
    ],
    "patchedDependencies": {}
  }
}
