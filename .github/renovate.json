{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base", ":timezone(Asia/Tokyo)", "group:allNonMajor"],
  "baseBranches": ["preview"],
  "labels": ["dependencies", "renovate"],
  "dependencyDashboard": true,
  "schedule": ["after 8am before 5pm on Monday"],
  "packageRules": [
    {
      "groupName": "oxc",
      "matchPackageNames": ["oxfmt", "oxlint"]
    },
    {
      "groupName": "markuplint",
      "matchPackageNames": ["markuplint"],
      "matchPackagePrefixes": ["@markuplint"]
    }
  ],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "postUpdateOptions": ["yarnDedupeHighest"]
}
